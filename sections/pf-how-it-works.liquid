{% comment %}
  PetFarewell - How It Works Section (Bilingual)
{% endcomment %}

{% liquid
  assign is_zh = false
  if request.locale.iso_code == 'zh-CN' or request.locale.iso_code == 'zh-TW'
    assign is_zh = true
  endif
  if is_zh
    assign eyebrow    = section.settings.eyebrow_zh    | default: section.settings.eyebrow
    assign heading    = section.settings.heading_zh    | default: section.settings.heading
    assign subheading = section.settings.subheading_zh | default: section.settings.subheading
    assign cta_label  = section.settings.cta_label_zh  | default: section.settings.cta_label
  else
    assign eyebrow    = section.settings.eyebrow
    assign heading    = section.settings.heading
    assign subheading = section.settings.subheading
    assign cta_label  = section.settings.cta_label
  endif
%}

<style>
  .pf-how-it-works {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .pf-how-it-works__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 2rem;
  }
  .pf-how-it-works__header {
    text-align: center;
    max-width: 600px;
    margin: 0 auto 4rem;
  }
  .pf-how-it-works__eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0 0 1rem;
  }
  .pf-how-it-works__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.8rem, 3vw, 2.5rem);
    line-height: 1.2;
    color: {{ section.settings.heading_color }};
    margin: 0 0 1rem;
  }
  .pf-how-it-works__subheading {
    font-size: 1rem;
    color: {{ section.settings.text_color }};
    line-height: 1.7;
    margin: 0;
  }
  .pf-how-it-works__steps {
    display: grid;
    grid-template-columns: repeat({{ section.blocks.size }}, 1fr);
    gap: 2rem;
    position: relative;
  }
  .pf-how-it-works__steps::before {
    content: '';
    position: absolute;
    top: 28px;
    left: calc(100% / {{ section.blocks.size }} / 2);
    right: calc(100% / {{ section.blocks.size }} / 2);
    height: 1px;
    background: {{ section.settings.accent_color }};
    opacity: 0.25;
  }
  .pf-how-it-works__step { text-align: center; position: relative; z-index: 1; }
  .pf-how-it-works__step-number {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: {{ section.settings.accent_color }};
    color: {{ section.settings.step_number_text_color }};
    font-family: var(--font-heading--family);
    font-size: 1.4rem;
    font-weight: 700;
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
  }
  .pf-how-it-works__step-icon {
    width: 56px; height: 56px;
    border-radius: 50%;
    background: {{ section.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    margin: 0 auto 1.5rem;
    font-size: 1.5rem;
    line-height: 1;
  }
  .pf-how-it-works__step-title {
    font-family: var(--font-heading--family);
    font-size: 1.1rem;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.6rem;
    font-weight: 600;
  }
  .pf-how-it-works__step-desc {
    font-size: 0.9rem;
    color: {{ section.settings.text_color }};
    line-height: 1.6;
    margin: 0;
  }
  .pf-how-it-works__cta { text-align: center; margin-top: 3.5rem; }
  .pf-how-it-works__cta a {
    display: inline-block;
    background: {{ section.settings.accent_color }};
    color: #FAF6EF;
    text-decoration: none;
    padding: 0.9rem 2.5rem;
    font-size: 0.95rem;
    font-weight: 600;
    letter-spacing: 0.03em;
    border-radius: 2px;
    transition: background 0.2s, transform 0.2s;
  }
  .pf-how-it-works__cta a:hover { background: #A67550; transform: translateY(-1px); }
  @media (max-width: 768px) {
    .pf-how-it-works__steps::before { display: none; }
    .pf-how-it-works__steps { grid-template-columns: 1fr; gap: 2.5rem; }
    .pf-how-it-works__step { display: flex; align-items: flex-start; text-align: left; gap: 1.2rem; }
    .pf-how-it-works__step-number,
    .pf-how-it-works__step-icon { flex-shrink: 0; margin: 0; }
  }
</style>

<section class="pf-how-it-works">
  <div class="pf-how-it-works__inner">
    <div class="pf-how-it-works__header">
      {% if eyebrow != blank %}<p class="pf-how-it-works__eyebrow">{{ eyebrow }}</p>{% endif %}
      {% if heading != blank %}<h2 class="pf-how-it-works__heading">{{ heading }}</h2>{% endif %}
      {% if subheading != blank %}<p class="pf-how-it-works__subheading">{{ subheading }}</p>{% endif %}
    </div>

    <div class="pf-how-it-works__steps">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'step' %}
            {% liquid
              if is_zh
                assign step_title = block.settings.title_zh | default: block.settings.title
                assign step_desc  = block.settings.description_zh | default: block.settings.description
              else
                assign step_title = block.settings.title
                assign step_desc  = block.settings.description
              endif
            %}
            <div class="pf-how-it-works__step" {{ block.shopify_attributes }}>
              {% if block.settings.emoji != blank %}
                <div class="pf-how-it-works__step-icon">{{ block.settings.emoji }}</div>
              {% else %}
                <div class="pf-how-it-works__step-number">{{ forloop.index }}</div>
              {% endif %}
              <div class="pf-how-it-works__step-body">
                <h3 class="pf-how-it-works__step-title">{{ step_title }}</h3>
                <p class="pf-how-it-works__step-desc">{{ step_desc }}</p>
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>

    {% if cta_label != blank and section.settings.cta_link != blank %}
      <div class="pf-how-it-works__cta">
        <a href="{{ section.settings.cta_link }}">{{ cta_label }}</a>
      </div>
    {% endif %}
  </div>
</section>

