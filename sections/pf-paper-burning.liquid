{%- comment -%}
  Section: pf-paper-burning.liquid
  纸钱代烧服务模块 — 中华文化传承仪式风格
  黑白金色调 · 庄重仪式感
{%- endcomment -%}

<style>
/* ===================================
   BASE
=================================== */
.pf-pb *,
.pf-pb *::before,
.pf-pb *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.pf-pb {
  background-color: #0d0d0d;
  color: #f5f0e8;
  font-family: 'Noto Serif SC', 'STSong', 'Songti SC', Georgia, serif;
  -webkit-font-smoothing: antialiased;
}

.pf-pb__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}

/* ===================================
   DECORATIVE DIVIDER
=================================== */
.pf-pb-divider {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 56px 0;
}

.pf-pb-divider::before,
.pf-pb-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(200, 169, 110, 0.4));
}

.pf-pb-divider::after {
  background: linear-gradient(to left, transparent, rgba(200, 169, 110, 0.4));
}

.pf-pb-divider__glyph {
  color: rgba(200, 169, 110, 0.7);
  font-size: 18px;
  flex-shrink: 0;
  letter-spacing: 8px;
}

/* ===================================
   MEDIA PLACEHOLDERS
=================================== */
.pf-pb-media {
  position: relative;
  background: #111;
  overflow: hidden;
}

.pf-pb-media img,
.pf-pb-media video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
}

.pf-pb-placeholder {
  width: 100%;
  height: 100%;
  min-height: 240px;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 16px;
  border: 1px dashed rgba(200, 169, 110, 0.2);
  color: rgba(200, 169, 110, 0.35);
}

.pf-pb-placeholder__icon {
  width: 48px;
  height: 48px;
  opacity: 0.5;
}

.pf-pb-placeholder__label {
  font-size: 11px;
  letter-spacing: 3px;
  text-transform: uppercase;
}

/* ===================================
   OVERLINE / LABEL STYLE
=================================== */
.pf-pb-label {
  display: block;
  font-size: 10px;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: rgba(200, 169, 110, 0.8);
  margin-bottom: 20px;
}

/* ===================================
   SECTION 1 — HERO
=================================== */
.pf-pb-hero {
  padding: 120px 32px 80px;
  text-align: center;
  position: relative;
}

.pf-pb-hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(200,169,110,0.07) 0%, transparent 70%);
  pointer-events: none;
}

.pf-pb-hero__inner {
  position: relative;
  z-index: 1;
}

.pf-pb-hero__title {
  font-size: clamp(40px, 7vw, 88px);
  font-weight: 300;
  line-height: 1.15;
  letter-spacing: 0.06em;
  margin-bottom: 12px;
}

.pf-pb-hero__title-accent {
  display: block;
  font-size: clamp(20px, 3vw, 36px);
  font-weight: 300;
  color: rgba(200, 169, 110, 0.9);
  letter-spacing: 0.15em;
  margin-top: 8px;
}

.pf-pb-hero__rule {
  width: 60px;
  height: 1px;
  background: rgba(200, 169, 110, 0.5);
  margin: 32px auto;
}

.pf-pb-hero__lead {
  font-size: clamp(15px, 2vw, 19px);
  line-height: 2.2;
  max-width: 640px;
  margin: 0 auto 72px;
  color: rgba(245, 240, 232, 0.72);
  font-weight: 300;
}

.pf-pb-hero__media {
  max-width: 960px;
  margin: 0 auto;
  aspect-ratio: 16/9;
  border: 1px solid rgba(200, 169, 110, 0.2);
}

/* ===================================
   SECTION 2 — CULTURAL ORIGIN
=================================== */
.pf-pb-origin {
  padding: 0 0 80px;
}

.pf-pb-origin__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}

.pf-pb-origin__content {
  padding: 0 0 0 16px;
}

.pf-pb-origin__heading {
  font-size: clamp(26px, 3.5vw, 44px);
  font-weight: 300;
  line-height: 1.5;
  letter-spacing: 0.05em;
  margin-bottom: 32px;
}

.pf-pb-origin__heading em {
  font-style: normal;
  color: rgba(200, 169, 110, 0.9);
}

.pf-pb-origin__body {
  font-size: 14px;
  line-height: 2.3;
  color: rgba(245, 240, 232, 0.68);
}

.pf-pb-origin__body p + p {
  margin-top: 20px;
}

.pf-pb-origin__media {
  aspect-ratio: 3/4;
  border: 1px solid rgba(200, 169, 110, 0.2);
}

/* ===================================
   SECTION 3 — STEPS NAVIGATOR
=================================== */
.pf-pb-steps-nav {
  padding: 0 32px 72px;
  text-align: center;
}

.pf-pb-steps-nav__subtitle {
  font-size: 13px;
  letter-spacing: 3px;
  color: rgba(245, 240, 232, 0.45);
  margin-bottom: 56px;
}

.pf-pb-steps-nav__track {
  display: flex;
  justify-content: center;
  align-items: flex-start;
  gap: 0;
  position: relative;
  max-width: 600px;
  margin: 0 auto;
}

.pf-pb-steps-nav__line {
  position: absolute;
  top: 19px;
  left: 16.5%;
  right: 16.5%;
  height: 1px;
  background: rgba(200, 169, 110, 0.2);
}

.pf-pb-step-node {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 14px;
  position: relative;
  z-index: 1;
}

.pf-pb-step-node__circle {
  width: 38px;
  height: 38px;
  border-radius: 50%;
  border: 1px solid rgba(200, 169, 110, 0.35);
  background: #0d0d0d;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 13px;
  color: rgba(200, 169, 110, 0.6);
  letter-spacing: 1px;
}

.pf-pb-step-node__text {
  font-size: 12px;
  letter-spacing: 2px;
  color: rgba(245, 240, 232, 0.38);
  text-align: center;
}

/* ===================================
   STEP SECTION WRAPPER
=================================== */
.pf-pb-step-section {
  padding: 0 32px 100px;
}

.pf-pb-step-section__header {
  text-align: center;
  margin-bottom: 64px;
}

.pf-pb-step-badge {
  display: inline-flex;
  align-items: center;
  gap: 16px;
  font-size: 10px;
  letter-spacing: 5px;
  color: rgba(200, 169, 110, 0.7);
  text-transform: uppercase;
  margin-bottom: 20px;
}

.pf-pb-step-badge::before,
.pf-pb-step-badge::after {
  content: '';
  width: 36px;
  height: 1px;
  background: rgba(200, 169, 110, 0.3);
}

.pf-pb-step-section__title {
  font-size: clamp(24px, 3.5vw, 40px);
  font-weight: 300;
  letter-spacing: 0.05em;
  margin-bottom: 20px;
}

.pf-pb-step-section__desc {
  font-size: 14px;
  line-height: 2.2;
  color: rgba(245, 240, 232, 0.6);
  max-width: 560px;
  margin: 0 auto;
}

/* ===================================
   STEP 1 — PRODUCTS PLACEHOLDER
=================================== */
.pf-pb-products-slot {
  border: 1px dashed rgba(200, 169, 110, 0.2);
  padding: 80px 40px;
  text-align: center;
}

.pf-pb-products-slot__glyph {
  font-size: 32px;
  color: rgba(200, 169, 110, 0.3);
  margin-bottom: 20px;
}

.pf-pb-products-slot__text {
  font-size: 12px;
  letter-spacing: 3px;
  color: rgba(245, 240, 232, 0.3);
  text-transform: uppercase;
}

/* ===================================
   STEP 2 — SERVICE CARDS
=================================== */
.pf-pb-services {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: rgba(200, 169, 110, 0.08);
}

.pf-pb-service-card {
  background: #0f0f0f;
  padding: 48px 36px 52px;
  cursor: pointer;
  transition: background 0.25s, border-color 0.25s;
  border: 2px solid transparent;
  outline: none;
  position: relative;
  user-select: none;
}

.pf-pb-service-card:hover {
  background: #141414;
  border-color: rgba(200, 169, 110, 0.25);
}

.pf-pb-service-card.is-selected {
  border-color: rgba(200, 169, 110, 0.8);
  background: #13100a;
}

.pf-pb-service-card__check {
  position: absolute;
  top: 20px;
  right: 24px;
  width: 22px;
  height: 22px;
  border: 1px solid rgba(200, 169, 110, 0.5);
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 10px;
  color: #c8a96e;
  opacity: 0;
  transition: opacity 0.2s;
}

.pf-pb-service-card.is-selected .pf-pb-service-card__check {
  opacity: 1;
}

.pf-pb-service-card__tier {
  font-size: 9px;
  letter-spacing: 5px;
  color: rgba(200, 169, 110, 0.65);
  text-transform: uppercase;
  margin-bottom: 14px;
}

.pf-pb-service-card__name {
  font-size: 24px;
  font-weight: 400;
  letter-spacing: 0.05em;
  margin-bottom: 20px;
}

.pf-pb-service-card__price {
  font-size: 44px;
  font-weight: 200;
  color: rgba(245, 240, 232, 0.9);
  margin-bottom: 32px;
  line-height: 1;
}

.pf-pb-service-card__price-currency {
  font-size: 18px;
  vertical-align: top;
  margin-top: 8px;
  display: inline-block;
  color: rgba(200, 169, 110, 0.7);
}

.pf-pb-service-card__rule {
  width: 32px;
  height: 1px;
  background: rgba(200, 169, 110, 0.3);
  margin-bottom: 28px;
}

.pf-pb-service-card__features {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
}

.pf-pb-service-card__features li {
  font-size: 13px;
  line-height: 1.7;
  color: rgba(245, 240, 232, 0.62);
  padding-left: 18px;
  position: relative;
}

.pf-pb-service-card__features li::before {
  content: '—';
  position: absolute;
  left: 0;
  color: rgba(200, 169, 110, 0.4);
}

/* ===================================
   STEP 3 — LOCATION CARDS
=================================== */
.pf-pb-locations {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  background: rgba(200, 169, 110, 0.08);
}

.pf-pb-location-card {
  background: #0f0f0f;
  cursor: pointer;
  overflow: hidden;
  position: relative;
  border: 2px solid transparent;
  transition: border-color 0.25s;
  outline: none;
  user-select: none;
}

.pf-pb-location-card:hover {
  border-color: rgba(200, 169, 110, 0.25);
}

.pf-pb-location-card.is-selected {
  border-color: rgba(200, 169, 110, 0.8);
}

.pf-pb-location-card.is-selected .pf-pb-location-check {
  opacity: 1;
}

.pf-pb-location-check {
  position: absolute;
  top: 16px;
  right: 20px;
  z-index: 3;
  width: 28px;
  height: 28px;
  border: 1px solid rgba(200, 169, 110, 0.7);
  border-radius: 50%;
  background: rgba(13, 13, 13, 0.6);
  backdrop-filter: blur(4px);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 11px;
  color: #c8a96e;
  opacity: 0;
  transition: opacity 0.25s;
}

.pf-pb-location-card__media {
  aspect-ratio: 16/9;
  overflow: hidden;
  position: relative;
}

.pf-pb-location-card__media img,
.pf-pb-location-card__media video {
  width: 100%;
  height: 100%;
  object-fit: cover;
  display: block;
  transition: transform 0.7s cubic-bezier(0.25, 0.46, 0.45, 0.94);
}

.pf-pb-location-card:hover .pf-pb-location-card__media img,
.pf-pb-location-card:hover .pf-pb-location-card__media video {
  transform: scale(1.04);
}

.pf-pb-location-card__body {
  padding: 36px 36px 40px;
}

.pf-pb-location-card__icon {
  font-size: 28px;
  margin-bottom: 16px;
  display: block;
}

.pf-pb-location-card__name {
  font-size: 22px;
  font-weight: 400;
  letter-spacing: 0.06em;
  margin-bottom: 6px;
}

.pf-pb-location-card__subtitle {
  font-size: 10px;
  letter-spacing: 4px;
  color: rgba(200, 169, 110, 0.65);
  text-transform: uppercase;
  margin-bottom: 24px;
}

.pf-pb-location-card__rule {
  width: 28px;
  height: 1px;
  background: rgba(200, 169, 110, 0.3);
  margin-bottom: 20px;
}

.pf-pb-location-card__story {
  font-size: 13px;
  line-height: 2.2;
  color: rgba(245, 240, 232, 0.58);
}

/* ===================================
   SECTION — CTA
=================================== */
.pf-pb-cta {
  padding: 80px 32px 120px;
  text-align: center;
  position: relative;
}

.pf-pb-cta::before {
  content: '';
  position: absolute;
  inset: 0;
  background: radial-gradient(ellipse 70% 80% at 50% 100%, rgba(200,169,110,0.05) 0%, transparent 70%);
  pointer-events: none;
}

.pf-pb-cta__inner {
  position: relative;
  z-index: 1;
}

.pf-pb-cta__title {
  font-size: clamp(22px, 3.5vw, 38px);
  font-weight: 300;
  letter-spacing: 0.06em;
  line-height: 1.6;
  margin-bottom: 12px;
}

.pf-pb-cta__subtitle {
  font-size: 13px;
  letter-spacing: 2px;
  color: rgba(245, 240, 232, 0.4);
  margin-bottom: 48px;
}

/* Selection Summary Panel */
.pf-pb-summary {
  display: none;
  max-width: 420px;
  margin: 0 auto 40px;
  border: 1px solid rgba(200, 169, 110, 0.25);
  background: rgba(200, 169, 110, 0.04);
}

.pf-pb-summary.is-visible {
  display: block;
}

.pf-pb-summary__row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 14px 28px;
  font-size: 12px;
  border-bottom: 1px solid rgba(245, 240, 232, 0.05);
}

.pf-pb-summary__row:last-child {
  border-bottom: none;
}

.pf-pb-summary__key {
  letter-spacing: 2px;
  color: rgba(245, 240, 232, 0.38);
  text-transform: uppercase;
}

.pf-pb-summary__val {
  color: rgba(200, 169, 110, 0.85);
  letter-spacing: 1px;
}

/* CTA Button */
.pf-pb-btn {
  display: inline-block;
  padding: 18px 56px;
  border: 1px solid rgba(200, 169, 110, 0.7);
  color: rgba(200, 169, 110, 0.85);
  background: transparent;
  font-family: inherit;
  font-size: 12px;
  letter-spacing: 4px;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.3s, color 0.3s, border-color 0.3s;
}

.pf-pb-btn:hover {
  background: rgba(200, 169, 110, 0.9);
  color: #0d0d0d;
  border-color: rgba(200, 169, 110, 0.9);
}

/* ===================================
   RESPONSIVE
=================================== */
@media (max-width: 900px) {
  .pf-pb-origin__grid {
    grid-template-columns: 1fr;
    gap: 48px;
  }

  .pf-pb-origin__media {
    order: -1;
    aspect-ratio: 3/2;
  }

  .pf-pb-services {
    grid-template-columns: 1fr;
    gap: 2px;
  }

  .pf-pb-locations {
    grid-template-columns: 1fr;
  }
}

@media (max-width: 640px) {
  .pf-pb__container,
  .pf-pb-hero,
  .pf-pb-step-section,
  .pf-pb-steps-nav,
  .pf-pb-cta {
    padding-left: 20px;
    padding-right: 20px;
  }

  .pf-pb-hero {
    padding-top: 80px;
  }

  .pf-pb-location-card__body {
    padding: 24px 24px 28px;
  }

  .pf-pb-service-card {
    padding: 36px 24px 40px;
  }
}
</style>

<div class="pf-pb">

  {%- comment -%} ===== HERO ===== {%- endcomment -%}
  <div class="pf-pb-hero">
    <div class="pf-pb-hero__inner">
      <span class="pf-pb-label">{{ section.settings.overline }}</span>

      <h2 class="pf-pb-hero__title">
        {{- section.settings.hero_title -}}
        {%- if section.settings.hero_title_accent != blank -%}
          <span class="pf-pb-hero__title-accent">{{ section.settings.hero_title_accent }}</span>
        {%- endif -%}
      </h2>

      <div class="pf-pb-hero__rule"></div>

      <p class="pf-pb-hero__lead">{{ section.settings.hero_lead }}</p>

      <div class="pf-pb-hero__media pf-pb-media">
        {%- if section.settings.hero_image != blank -%}
          <img
            src="{{ section.settings.hero_image | image_url: width: 1920 }}"
            alt="{{ section.settings.hero_title }}"
            loading="lazy"
          >
        {%- else -%}
          <div class="pf-pb-placeholder">
            <svg class="pf-pb-placeholder__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <span class="pf-pb-placeholder__label">主视觉图片 / 仪式视频</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ===== DIVIDER ===== {%- endcomment -%}
  <div class="pf-pb__container">
    <div class="pf-pb-divider">
      <span class="pf-pb-divider__glyph">一 ☽ 一</span>
    </div>
  </div>

  {%- comment -%} ===== CULTURAL ORIGIN ===== {%- endcomment -%}
  <div class="pf-pb-origin">
    <div class="pf-pb__container">
      <div class="pf-pb-origin__grid">
        <div class="pf-pb-origin__content">
          <span class="pf-pb-label">{{ section.settings.origin_label }}</span>
          <h3 class="pf-pb-origin__heading">{{ section.settings.origin_heading }}</h3>
          <div class="pf-pb-origin__body">
            <p>{{ section.settings.origin_text_1 }}</p>
            <p>{{ section.settings.origin_text_2 }}</p>
            {%- if section.settings.origin_text_3 != blank -%}
              <p>{{ section.settings.origin_text_3 }}</p>
            {%- endif -%}
          </div>
        </div>

        <div class="pf-pb-origin__media pf-pb-media">
          {%- if section.settings.origin_image != blank -%}
            <img
              src="{{ section.settings.origin_image | image_url: width: 960 }}"
              alt="{{ section.settings.origin_heading }}"
              loading="lazy"
            >
          {%- else -%}
            <div class="pf-pb-placeholder">
              <svg class="pf-pb-placeholder__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <span class="pf-pb-placeholder__label">仪式场景图片</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ===== DIVIDER ===== {%- endcomment -%}
  <div class="pf-pb__container">
    <div class="pf-pb-divider">
      <span class="pf-pb-divider__glyph">⊕</span>
    </div>
  </div>

  {%- comment -%} ===== STEPS NAVIGATOR ===== {%- endcomment -%}
  <div class="pf-pb-steps-nav">
    <div class="pf-pb__container">
      <span class="pf-pb-label" style="display:block;text-align:center;margin-bottom:8px;">仪式定制流程</span>
      <p class="pf-pb-steps-nav__subtitle">{{ section.settings.steps_subtitle }}</p>
      <div class="pf-pb-steps-nav__track">
        <div class="pf-pb-steps-nav__line"></div>
        <div class="pf-pb-step-node">
          <div class="pf-pb-step-node__circle">一</div>
          <div class="pf-pb-step-node__text">选择祭品</div>
        </div>
        <div class="pf-pb-step-node">
          <div class="pf-pb-step-node__circle">二</div>
          <div class="pf-pb-step-node__text">选择服务</div>
        </div>
        <div class="pf-pb-step-node">
          <div class="pf-pb-step-node__circle">三</div>
          <div class="pf-pb-step-node__text">选择圣地</div>
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ===== STEP 1: PRODUCTS ===== {%- endcomment -%}
  <div class="pf-pb-step-section" id="pf-step-1">
    <div class="pf-pb__container">
      <div class="pf-pb-step-section__header">
        <div class="pf-pb-step-badge">第一步</div>
        <h3 class="pf-pb-step-section__title">{{ section.settings.products_title }}</h3>
        <p class="pf-pb-step-section__desc">{{ section.settings.products_desc }}</p>
      </div>
      <div class="pf-pb-products-slot">
        <div class="pf-pb-products-slot__glyph">祭</div>
        <p class="pf-pb-products-slot__text">祭品产品列表 · 即将上线</p>
      </div>
    </div>
  </div>

  {%- comment -%} ===== STEP 2: SERVICES ===== {%- endcomment -%}
  <div class="pf-pb-step-section" id="pf-step-2">
    <div class="pf-pb__container">
      <div class="pf-pb-step-section__header">
        <div class="pf-pb-step-badge">第二步</div>
        <h3 class="pf-pb-step-section__title">{{ section.settings.services_title }}</h3>
        <p class="pf-pb-step-section__desc">{{ section.settings.services_desc }}</p>
      </div>

      <div class="pf-pb-services" role="radiogroup" aria-label="代烧服务档位">
        {%- for block in section.blocks -%}
          {%- if block.type == 'service' -%}
            <div
              class="pf-pb-service-card"
              role="radio"
              aria-checked="false"
              tabindex="0"
              data-type="service"
              data-name="{{ block.settings.name }}"
              data-price="{{ block.settings.price }}"
              {{ block.shopify_attributes }}
            >
              <div class="pf-pb-service-card__check" aria-hidden="true">✓</div>
              <p class="pf-pb-service-card__tier">{{ block.settings.tier }}</p>
              <h4 class="pf-pb-service-card__name">{{ block.settings.name }}</h4>
              <p class="pf-pb-service-card__price">
                <span class="pf-pb-service-card__price-currency">$</span>{{ block.settings.price }}
              </p>
              <div class="pf-pb-service-card__rule"></div>
              <ul class="pf-pb-service-card__features" aria-label="{{ block.settings.name }} 包含内容">
                {%- if block.settings.feature_1 != blank -%}<li>{{ block.settings.feature_1 }}</li>{%- endif -%}
                {%- if block.settings.feature_2 != blank -%}<li>{{ block.settings.feature_2 }}</li>{%- endif -%}
                {%- if block.settings.feature_3 != blank -%}<li>{{ block.settings.feature_3 }}</li>{%- endif -%}
                {%- if block.settings.feature_4 != blank -%}<li>{{ block.settings.feature_4 }}</li>{%- endif -%}
                {%- if block.settings.feature_5 != blank -%}<li>{{ block.settings.feature_5 }}</li>{%- endif -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} ===== STEP 3: LOCATIONS ===== {%- endcomment -%}
  <div class="pf-pb-step-section" id="pf-step-3">
    <div class="pf-pb__container">
      <div class="pf-pb-step-section__header">
        <div class="pf-pb-step-badge">第三步</div>
        <h3 class="pf-pb-step-section__title">{{ section.settings.locations_title }}</h3>
        <p class="pf-pb-step-section__desc">{{ section.settings.locations_desc }}</p>
      </div>

      <div class="pf-pb-locations" role="radiogroup" aria-label="送行圣地">
        {%- for block in section.blocks -%}
          {%- if block.type == 'location' -%}
            <div
              class="pf-pb-location-card"
              role="radio"
              aria-checked="false"
              tabindex="0"
              data-type="location"
              data-name="{{ block.settings.name }}"
              {{ block.shopify_attributes }}
            >
              <div class="pf-pb-location-check" aria-hidden="true">✓</div>

              <div class="pf-pb-location-card__media">
                {%- if block.settings.image != blank -%}
                  <img
                    src="{{ block.settings.image | image_url: width: 1000 }}"
                    alt="{{ block.settings.name }}"
                    loading="lazy"
                  >
                {%- else -%}
                  <div class="pf-pb-placeholder" style="min-height:200px">
                    <svg class="pf-pb-placeholder__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                    <span class="pf-pb-placeholder__label">{{ block.settings.name }} · 实景图片</span>
                  </div>
                {%- endif -%}
              </div>

              <div class="pf-pb-location-card__body">
                <span class="pf-pb-location-card__icon" aria-hidden="true">{{ block.settings.icon }}</span>
                <h4 class="pf-pb-location-card__name">{{ block.settings.name }}</h4>
                <p class="pf-pb-location-card__subtitle">{{ block.settings.subtitle }}</p>
                <div class="pf-pb-location-card__rule"></div>
                <p class="pf-pb-location-card__story">{{ block.settings.story }}</p>
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} ===== DIVIDER ===== {%- endcomment -%}
  <div class="pf-pb__container">
    <div class="pf-pb-divider">
      <span class="pf-pb-divider__glyph">一 ☽ 一</span>
    </div>
  </div>

  {%- comment -%} ===== CTA ===== {%- endcomment -%}
  <div class="pf-pb-cta">
    <div class="pf-pb-cta__inner">
      <span class="pf-pb-label" style="display:block;text-align:center;margin-bottom:20px;">完成定制</span>
      <h3 class="pf-pb-cta__title">{{ section.settings.cta_title }}</h3>
      <p class="pf-pb-cta__subtitle">{{ section.settings.cta_subtitle }}</p>

      <div class="pf-pb-summary" id="pf-pb-summary" aria-live="polite">
        <div class="pf-pb-summary__row">
          <span class="pf-pb-summary__key">已选服务</span>
          <span class="pf-pb-summary__val" id="pf-summary-service">—</span>
        </div>
        <div class="pf-pb-summary__row">
          <span class="pf-pb-summary__key">送行圣地</span>
          <span class="pf-pb-summary__val" id="pf-summary-location">—</span>
        </div>
      </div>

      <a href="{{ section.settings.cta_url }}" class="pf-pb-btn">
        {{ section.settings.cta_button }}
      </a>
    </div>
  </div>

</div>

<script>
(function () {
  'use strict';

  var serviceCards = Array.prototype.slice.call(document.querySelectorAll('.pf-pb-service-card'));
  var locationCards = Array.prototype.slice.call(document.querySelectorAll('.pf-pb-location-card'));
  var summary = document.getElementById('pf-pb-summary');
  var summaryService = document.getElementById('pf-summary-service');
  var summaryLocation = document.getElementById('pf-summary-location');

  var state = { service: null, location: null };

  function updateSummary() {
    if (state.service || state.location) {
      summary.classList.add('is-visible');
      summaryService.textContent = state.service ? state.service.name + '  $' + state.service.price : '—';
      summaryLocation.textContent = state.location ? state.location.name : '—';
    }
  }

  function selectService(card) {
    serviceCards.forEach(function (c) {
      c.classList.remove('is-selected');
      c.setAttribute('aria-checked', 'false');
    });
    card.classList.add('is-selected');
    card.setAttribute('aria-checked', 'true');
    state.service = { name: card.dataset.name, price: card.dataset.price };
    updateSummary();
  }

  function selectLocation(card) {
    locationCards.forEach(function (c) {
      c.classList.remove('is-selected');
      c.setAttribute('aria-checked', 'false');
    });
    card.classList.add('is-selected');
    card.setAttribute('aria-checked', 'true');
    state.location = { name: card.dataset.name };
    updateSummary();
  }

  serviceCards.forEach(function (card) {
    card.addEventListener('click', function () { selectService(card); });
    card.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectService(card); }
    });
  });

  locationCards.forEach(function (card) {
    card.addEventListener('click', function () { selectLocation(card); });
    card.addEventListener('keydown', function (e) {
      if (e.key === 'Enter' || e.key === ' ') { e.preventDefault(); selectLocation(card); }
    });
  });
})();
</script>

