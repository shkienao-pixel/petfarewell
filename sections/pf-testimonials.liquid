{% comment %}
  PetFarewell - Testimonials Section (Bilingual)
{% endcomment %}

{% liquid
  assign is_zh = false
  if request.locale.iso_code == 'zh-CN' or request.locale.iso_code == 'zh-TW'
    assign is_zh = true
  endif
  if is_zh
    assign eyebrow = section.settings.eyebrow_zh | default: section.settings.eyebrow
    assign heading = section.settings.heading_zh | default: section.settings.heading
  else
    assign eyebrow = section.settings.eyebrow
    assign heading = section.settings.heading
  endif
%}

<style>
  .pf-testimonials {
    background-color: {{ section.settings.background_color }};
    padding: {{ section.settings.padding_top }}px 0 {{ section.settings.padding_bottom }}px;
  }
  .pf-testimonials__inner {
    max-width: var(--page-width, 1200px);
    margin: 0 auto;
    padding: 0 2rem;
  }
  .pf-testimonials__header {
    text-align: center;
    max-width: 500px;
    margin: 0 auto 3.5rem;
  }
  .pf-testimonials__eyebrow {
    font-size: 0.8rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin: 0 0 0.8rem;
  }
  .pf-testimonials__heading {
    font-family: var(--font-heading--family);
    font-size: clamp(1.6rem, 2.5vw, 2.2rem);
    color: {{ section.settings.heading_color }};
    margin: 0;
    line-height: 1.2;
  }
  .pf-testimonials__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(300px, 1fr));
    gap: 1.5rem;
  }
  .pf-testimonials__card {
    background: {{ section.settings.card_background }};
    border-radius: 12px;
    padding: 2rem;
  }
  .pf-testimonials__stars {
    display: flex;
    gap: 3px;
    margin-bottom: 1rem;
    color: {{ section.settings.star_color }};
  }
  .pf-testimonials__stars svg { width: 18px; height: 18px; }
  .pf-testimonials__quote {
    font-size: 0.95rem;
    line-height: 1.7;
    color: {{ section.settings.quote_color }};
    margin: 0 0 1.5rem;
    font-style: italic;
  }
  .pf-testimonials__author { display: flex; align-items: center; gap: 0.8rem; }
  .pf-testimonials__avatar {
    width: 44px; height: 44px;
    border-radius: 50%;
    overflow: hidden;
    background: {{ section.settings.accent_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    color: #FAF6EF;
    font-family: var(--font-heading--family);
    font-size: 1.1rem;
    font-weight: 700;
    flex-shrink: 0;
  }
  .pf-testimonials__avatar img { width: 100%; height: 100%; object-fit: cover; }
  .pf-testimonials__author-name {
    font-weight: 600;
    font-size: 0.9rem;
    color: {{ section.settings.heading_color }};
    margin: 0 0 0.1rem;
  }
  .pf-testimonials__author-pet {
    font-size: 0.8rem;
    color: {{ section.settings.accent_color }};
    margin: 0;
  }
  @media (max-width: 768px) {
    .pf-testimonials__grid { grid-template-columns: 1fr; }
  }
</style>

<section class="pf-testimonials">
  <div class="pf-testimonials__inner">
    <div class="pf-testimonials__header">
      {% if eyebrow != blank %}<p class="pf-testimonials__eyebrow">{{ eyebrow }}</p>{% endif %}
      {% if heading != blank %}<h2 class="pf-testimonials__heading">{{ heading }}</h2>{% endif %}
    </div>
    <div class="pf-testimonials__grid">
      {% for block in section.blocks %}
        {% case block.type %}
          {% when 'testimonial' %}
            {% liquid
              if is_zh
                assign t_quote = block.settings.quote_zh | default: block.settings.quote
                assign t_name  = block.settings.author_name_zh | default: block.settings.author_name
                assign t_pet   = block.settings.pet_name_zh | default: block.settings.pet_name
              else
                assign t_quote = block.settings.quote
                assign t_name  = block.settings.author_name
                assign t_pet   = block.settings.pet_name
              endif
            %}
            <div class="pf-testimonials__card" {{ block.shopify_attributes }}>
              <div class="pf-testimonials__stars">
                {% assign star_count = block.settings.rating | default: 5 %}
                {% for i in (1..star_count) %}
                  <svg viewBox="0 0 24 24" fill="currentColor">
                    <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/>
                  </svg>
                {% endfor %}
              </div>
              {% if t_quote != blank %}
                <p class="pf-testimonials__quote">"{{ t_quote }}"</p>
              {% endif %}
              <div class="pf-testimonials__author">
                <div class="pf-testimonials__avatar">
                  {% if block.settings.avatar != blank %}
                    <img src="{{ block.settings.avatar | image_url: width: 88 }}" alt="{{ t_name }}">
                  {% else %}
                    {{ t_name | slice: 0 }}
                  {% endif %}
                </div>
                <div>
                  <p class="pf-testimonials__author-name">{{ t_name }}</p>
                  {% if t_pet != blank %}<p class="pf-testimonials__author-pet">🐾 {{ t_pet }}</p>{% endif %}
                </div>
              </div>
            </div>
        {% endcase %}
      {% endfor %}
    </div>
  </div>
</section>

{% schema %}
{
  "name": "Testimonials",
  "tag": "section",
  "settings": [
    {
      "type": "header",
      "content": "English"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow (EN)",
