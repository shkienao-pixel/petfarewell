{%- comment -%}
  Section: pf-digital-shrine.liquid
  电子祠堂落地页 — 功能预留版
  黑白金色调 · 与纸钱代烧风格一致
{%- endcomment -%}

<style>
.pf-ds *,
.pf-ds *::before,
.pf-ds *::after {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
}

.pf-ds {
  background-color: #0d0d0d;
  color: #f5f0e8;
  font-family: 'Noto Serif SC', 'STSong', 'Songti SC', Georgia, serif;
  -webkit-font-smoothing: antialiased;
}

.pf-ds__container {
  max-width: 1200px;
  margin: 0 auto;
  padding: 0 32px;
}

/* Divider */
.pf-ds-divider {
  display: flex;
  align-items: center;
  gap: 20px;
  padding: 56px 0;
}
.pf-ds-divider::before,
.pf-ds-divider::after {
  content: '';
  flex: 1;
  height: 1px;
  background: linear-gradient(to right, transparent, rgba(200,169,110,0.4));
}
.pf-ds-divider::after {
  background: linear-gradient(to left, transparent, rgba(200,169,110,0.4));
}
.pf-ds-divider__glyph {
  color: rgba(200,169,110,0.7);
  font-size: 16px;
  flex-shrink: 0;
  letter-spacing: 6px;
}

.pf-ds-label {
  display: block;
  font-size: 10px;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: rgba(200,169,110,0.8);
  margin-bottom: 20px;
}

/* Media placeholder */
.pf-ds-media {
  position: relative;
  background: #111;
  overflow: hidden;
}
.pf-ds-media img { width:100%; height:100%; object-fit:cover; display:block; }
.pf-ds-placeholder {
  width:100%; height:100%; min-height:200px;
  display:flex; flex-direction:column;
  align-items:center; justify-content:center; gap:14px;
  border: 1px dashed rgba(200,169,110,0.2);
  color: rgba(200,169,110,0.35);
}
.pf-ds-placeholder__icon { width:40px; height:40px; opacity:0.5; }
.pf-ds-placeholder__label { font-size:11px; letter-spacing:3px; text-transform:uppercase; }

/* ===== HERO ===== */
.pf-ds-hero {
  padding: 120px 32px 80px;
  text-align: center;
  position: relative;
}
.pf-ds-hero::before {
  content:'';
  position:absolute; inset:0;
  background: radial-gradient(ellipse 80% 60% at 50% 0%, rgba(200,169,110,0.06) 0%, transparent 70%);
  pointer-events:none;
}
.pf-ds-hero__inner { position:relative; z-index:1; }

.pf-ds-hero__title {
  font-size: clamp(36px, 6vw, 80px);
  font-weight: 300;
  line-height: 1.2;
  letter-spacing: 0.06em;
  margin-bottom: 12px;
}
.pf-ds-hero__title-accent {
  display: block;
  font-size: clamp(16px, 2.5vw, 28px);
  font-weight: 300;
  color: rgba(200,169,110,0.85);
  letter-spacing: 0.2em;
  margin-top: 10px;
}
.pf-ds-hero__rule {
  width: 60px; height: 1px;
  background: rgba(200,169,110,0.5);
  margin: 32px auto;
}
.pf-ds-hero__lead {
  font-size: clamp(15px, 2vw, 18px);
  line-height: 2.2;
  max-width: 620px;
  margin: 0 auto 72px;
  color: rgba(245,240,232,0.7);
  font-weight: 300;
}
.pf-ds-hero__media {
  max-width: 960px;
  margin: 0 auto;
  aspect-ratio: 16/9;
  border: 1px solid rgba(200,169,110,0.2);
}

/* ===== WHAT IS IT ===== */
.pf-ds-intro {
  padding: 0 0 80px;
}
.pf-ds-intro__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 80px;
  align-items: center;
}
.pf-ds-intro__heading {
  font-size: clamp(24px, 3.5vw, 40px);
  font-weight: 300;
  line-height: 1.5;
  letter-spacing: 0.05em;
  margin-bottom: 28px;
}
.pf-ds-intro__heading em {
  font-style: normal;
  color: rgba(200,169,110,0.85);
}
.pf-ds-intro__body {
  font-size: 14px;
  line-height: 2.3;
  color: rgba(245,240,232,0.65);
}
.pf-ds-intro__body p + p { margin-top: 18px; }
.pf-ds-intro__media {
  aspect-ratio: 4/5;
  border: 1px solid rgba(200,169,110,0.2);
}

/* ===== FEATURES ===== */
.pf-ds-features { padding: 0 0 100px; }
.pf-ds-features__header { text-align:center; margin-bottom:64px; }
.pf-ds-features__title {
  font-size: clamp(22px, 3vw, 36px);
  font-weight: 300;
  letter-spacing: 0.05em;
  margin-bottom: 16px;
}
.pf-ds-features__desc {
  font-size: 14px;
  line-height: 2;
  color: rgba(245,240,232,0.55);
  max-width: 500px;
  margin: 0 auto;
}

.pf-ds-features__grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 2px;
  background: rgba(200,169,110,0.08);
}

.pf-ds-feature-card {
  background: #0f0f0f;
  padding: 0;
  overflow: hidden;
}
.pf-ds-feature-card__media {
  aspect-ratio: 16/9;
  overflow: hidden;
}
.pf-ds-feature-card__media img {
  width:100%; height:100%; object-fit:cover;
  transition: transform 0.6s ease;
}
.pf-ds-feature-card:hover .pf-ds-feature-card__media img {
  transform: scale(1.04);
}
.pf-ds-feature-card__body {
  padding: 32px 36px 36px;
}
.pf-ds-feature-card__icon {
  font-size: 26px;
  margin-bottom: 14px;
  display: block;
}
.pf-ds-feature-card__title {
  font-size: 18px;
  font-weight: 400;
  letter-spacing: 0.05em;
  margin-bottom: 12px;
}
.pf-ds-feature-card__tag {
  font-size: 9px;
  letter-spacing: 4px;
  color: rgba(200,169,110,0.6);
  text-transform: uppercase;
  margin-bottom: 16px;
}
.pf-ds-feature-card__desc {
  font-size: 13px;
  line-height: 2.1;
  color: rgba(245,240,232,0.58);
}

/* Coming soon badge */
.pf-ds-badge-soon {
  display: inline-block;
  font-size: 9px;
  letter-spacing: 3px;
  text-transform: uppercase;
  color: rgba(200,169,110,0.5);
  border: 1px solid rgba(200,169,110,0.2);
  padding: 3px 10px;
  margin-top: 12px;
}

/* ===== HOW IT WORKS ===== */
.pf-ds-how { padding: 0 0 100px; }
.pf-ds-how__header { text-align:center; margin-bottom:64px; }
.pf-ds-how__title {
  font-size: clamp(22px, 3vw, 36px);
  font-weight: 300;
  letter-spacing: 0.05em;
  margin-bottom: 16px;
}

.pf-ds-how__steps {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 2px;
  background: rgba(200,169,110,0.08);
}
.pf-ds-how__step {
  background: #0f0f0f;
  padding: 48px 36px;
  text-align: center;
}
.pf-ds-how__step-num {
  width: 48px; height: 48px;
  border-radius: 50%;
  border: 1px solid rgba(200,169,110,0.35);
  display: flex; align-items:center; justify-content:center;
  font-size: 14px;
  color: rgba(200,169,110,0.7);
  margin: 0 auto 24px;
}
.pf-ds-how__step-title {
  font-size: 17px;
  font-weight: 400;
  letter-spacing: 0.05em;
  margin-bottom: 14px;
}
.pf-ds-how__step-desc {
  font-size: 13px;
  line-height: 2;
  color: rgba(245,240,232,0.55);
}

/* ===== PRICING ===== */
.pf-ds-pricing { padding: 0 0 100px; }
.pf-ds-pricing__header { text-align:center; margin-bottom:64px; }
.pf-ds-pricing__title {
  font-size: clamp(22px, 3vw, 36px);
  font-weight: 300;
  letter-spacing: 0.05em;
  margin-bottom: 16px;
}

.pf-ds-pricing__grid {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 2px;
  background: rgba(200,169,110,0.08);
  max-width: 800px;
  margin: 0 auto;
}
.pf-ds-plan {
  background: #0f0f0f;
  padding: 52px 40px;
  position: relative;
}
.pf-ds-plan--featured {
  background: #13100a;
}
.pf-ds-plan__label {
  font-size: 9px;
  letter-spacing: 5px;
  text-transform: uppercase;
  color: rgba(200,169,110,0.65);
  margin-bottom: 16px;
}
.pf-ds-plan__name {
  font-size: 24px;
  font-weight: 400;
  letter-spacing: 0.05em;
  margin-bottom: 20px;
}
.pf-ds-plan__price {
  font-size: 48px;
  font-weight: 200;
  color: rgba(245,240,232,0.9);
  line-height: 1;
  margin-bottom: 8px;
}
.pf-ds-plan__price-note {
  font-size: 12px;
  letter-spacing: 1px;
  color: rgba(245,240,232,0.35);
  margin-bottom: 36px;
}
.pf-ds-plan__rule {
  width: 32px; height: 1px;
  background: rgba(200,169,110,0.3);
  margin-bottom: 28px;
}
.pf-ds-plan__list {
  list-style: none;
  display: flex;
  flex-direction: column;
  gap: 12px;
  margin-bottom: 40px;
}
.pf-ds-plan__list li {
  font-size: 13px;
  line-height: 1.7;
  color: rgba(245,240,232,0.62);
  padding-left: 18px;
  position: relative;
}
.pf-ds-plan__list li::before {
  content: '—';
  position: absolute; left: 0;
  color: rgba(200,169,110,0.4);
}
.pf-ds-plan__list li.disabled {
  color: rgba(245,240,232,0.25);
}
.pf-ds-plan__list li.disabled::before {
  content: '×';
  color: rgba(245,240,232,0.15);
}

/* ===== CTA ===== */
.pf-ds-cta {
  padding: 80px 32px 120px;
  text-align: center;
  position: relative;
}
.pf-ds-cta::before {
  content:'';
  position:absolute; inset:0;
  background: radial-gradient(ellipse 70% 80% at 50% 100%, rgba(200,169,110,0.05) 0%, transparent 70%);
  pointer-events:none;
}
.pf-ds-cta__inner { position:relative; z-index:1; }
.pf-ds-cta__title {
  font-size: clamp(20px, 3vw, 36px);
  font-weight: 300;
  letter-spacing: 0.06em;
  line-height: 1.6;
  margin-bottom: 12px;
}
.pf-ds-cta__sub {
  font-size: 13px;
  letter-spacing: 2px;
  color: rgba(245,240,232,0.38);
  margin-bottom: 16px;
}
.pf-ds-cta__coming {
  display: inline-block;
  font-size: 10px;
  letter-spacing: 4px;
  text-transform: uppercase;
  color: rgba(200,169,110,0.5);
  border: 1px solid rgba(200,169,110,0.2);
  padding: 6px 20px;
  margin-bottom: 32px;
}
.pf-ds-btn {
  display: inline-block;
  padding: 18px 56px;
  border: 1px solid rgba(200,169,110,0.7);
  color: rgba(200,169,110,0.85);
  background: transparent;
  font-family: inherit;
  font-size: 12px;
  letter-spacing: 4px;
  text-transform: uppercase;
  text-decoration: none;
  cursor: pointer;
  transition: background 0.3s, color 0.3s;
}
.pf-ds-btn:hover {
  background: rgba(200,169,110,0.9);
  color: #0d0d0d;
}

/* Responsive */
@media (max-width: 900px) {
  .pf-ds-intro__grid { grid-template-columns:1fr; gap:40px; }
  .pf-ds-intro__media { order:-1; aspect-ratio:3/2; }
  .pf-ds-features__grid { grid-template-columns:1fr; }
  .pf-ds-how__steps { grid-template-columns:1fr; }
  .pf-ds-pricing__grid { grid-template-columns:1fr; }
}
@media (max-width: 640px) {
  .pf-ds__container,
  .pf-ds-hero,
  .pf-ds-features,
  .pf-ds-how,
  .pf-ds-pricing,
  .pf-ds-cta { padding-left:20px; padding-right:20px; }
  .pf-ds-hero { padding-top:80px; }
}
</style>

<div class="pf-ds">

  {%- comment -%} ===== HERO ===== {%- endcomment -%}
  <div class="pf-ds-hero">
    <div class="pf-ds-hero__inner">
      <span class="pf-ds-label">{{ section.settings.overline }}</span>
      <h2 class="pf-ds-hero__title">
        {{ section.settings.hero_title }}
        {%- if section.settings.hero_title_accent != blank -%}
          <span class="pf-ds-hero__title-accent">{{ section.settings.hero_title_accent }}</span>
        {%- endif -%}
      </h2>
      <div class="pf-ds-hero__rule"></div>
      <p class="pf-ds-hero__lead">{{ section.settings.hero_lead }}</p>
      <div class="pf-ds-hero__media pf-ds-media">
        {%- if section.settings.hero_image != blank -%}
          <img src="{{ section.settings.hero_image | image_url: width: 1920 }}" alt="{{ section.settings.hero_title }}" loading="lazy">
        {%- else -%}
          <div class="pf-ds-placeholder">
            <svg class="pf-ds-placeholder__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
              <rect x="3" y="3" width="18" height="18" rx="2"/>
              <circle cx="8.5" cy="8.5" r="1.5"/>
              <polyline points="21 15 16 10 5 21"/>
            </svg>
            <span class="pf-ds-placeholder__label">主视觉图片 / 视频</span>
          </div>
        {%- endif -%}
      </div>
    </div>
  </div>

  {%- comment -%} ===== DIVIDER ===== {%- endcomment -%}
  <div class="pf-ds__container">
    <div class="pf-ds-divider"><span class="pf-ds-divider__glyph">一 ☽ 一</span></div>
  </div>

  {%- comment -%} ===== WHAT IS IT ===== {%- endcomment -%}
  <div class="pf-ds-intro">
    <div class="pf-ds__container">
      <div class="pf-ds-intro__grid">
        <div>
          <span class="pf-ds-label">{{ section.settings.intro_label }}</span>
          <h3 class="pf-ds-intro__heading">{{ section.settings.intro_heading }}</h3>
          <div class="pf-ds-intro__body">
            <p>{{ section.settings.intro_text_1 }}</p>
            <p>{{ section.settings.intro_text_2 }}</p>
          </div>
        </div>
        <div class="pf-ds-intro__media pf-ds-media">
          {%- if section.settings.intro_image != blank -%}
            <img src="{{ section.settings.intro_image | image_url: width: 900 }}" alt="{{ section.settings.intro_heading }}" loading="lazy">
          {%- else -%}
            <div class="pf-ds-placeholder">
              <svg class="pf-ds-placeholder__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                <rect x="3" y="3" width="18" height="18" rx="2"/>
                <circle cx="8.5" cy="8.5" r="1.5"/>
                <polyline points="21 15 16 10 5 21"/>
              </svg>
              <span class="pf-ds-placeholder__label">祠堂界面展示图</span>
            </div>
          {%- endif -%}
        </div>
      </div>
    </div>
  </div>

  {%- comment -%} ===== DIVIDER ===== {%- endcomment -%}
  <div class="pf-ds__container">
    <div class="pf-ds-divider"><span class="pf-ds-divider__glyph">⊕</span></div>
  </div>

  {%- comment -%} ===== FEATURES ===== {%- endcomment -%}
  <div class="pf-ds-features">
    <div class="pf-ds__container">
      <div class="pf-ds-features__header">
        <span class="pf-ds-label" style="text-align:center">核心功能</span>
        <h3 class="pf-ds-features__title">{{ section.settings.features_title }}</h3>
        <p class="pf-ds-features__desc">{{ section.settings.features_desc }}</p>
      </div>

      <div class="pf-ds-features__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'feature' -%}
            <div class="pf-ds-feature-card" {{ block.shopify_attributes }}>
              <div class="pf-ds-feature-card__media">
                {%- if block.settings.image != blank -%}
                  <img src="{{ block.settings.image | image_url: width: 900 }}" alt="{{ block.settings.title }}" loading="lazy">
                {%- else -%}
                  <div class="pf-ds-placeholder" style="min-height:180px">
                    <svg class="pf-ds-placeholder__icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1">
                      <rect x="3" y="3" width="18" height="18" rx="2"/>
                      <circle cx="8.5" cy="8.5" r="1.5"/>
                      <polyline points="21 15 16 10 5 21"/>
                    </svg>
                    <span class="pf-ds-placeholder__label">{{ block.settings.title }}</span>
                  </div>
                {%- endif -%}
              </div>
              <div class="pf-ds-feature-card__body">
                <span class="pf-ds-feature-card__icon" aria-hidden="true">{{ block.settings.icon }}</span>
                <p class="pf-ds-feature-card__tag">{{ block.settings.tag }}</p>
                <h4 class="pf-ds-feature-card__title">{{ block.settings.title }}</h4>
                <p class="pf-ds-feature-card__desc">{{ block.settings.desc }}</p>
                {%- if block.settings.coming_soon -%}
                  <span class="pf-ds-badge-soon">即将上线</span>
                {%- endif -%}
              </div>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} ===== HOW IT WORKS ===== {%- endcomment -%}
  <div class="pf-ds-how">
    <div class="pf-ds__container">
      <div class="pf-ds-how__header">
        <span class="pf-ds-label" style="text-align:center">创建流程</span>
        <h3 class="pf-ds-how__title">{{ section.settings.how_title }}</h3>
      </div>
      <div class="pf-ds-how__steps">
        {%- for block in section.blocks -%}
          {%- if block.type == 'step' -%}
            <div class="pf-ds-how__step" {{ block.shopify_attributes }}>
              <div class="pf-ds-how__step-num">{{ forloop.index }}</div>
              <h4 class="pf-ds-how__step-title">{{ block.settings.title }}</h4>
              <p class="pf-ds-how__step-desc">{{ block.settings.desc }}</p>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} ===== PRICING ===== {%- endcomment -%}
  <div class="pf-ds-pricing">
    <div class="pf-ds__container">
      <div class="pf-ds-pricing__header">
        <span class="pf-ds-label" style="text-align:center">套餐</span>
        <h3 class="pf-ds-pricing__title">{{ section.settings.pricing_title }}</h3>
      </div>
      <div class="pf-ds-pricing__grid">
        {%- for block in section.blocks -%}
          {%- if block.type == 'plan' -%}
            <div class="pf-ds-plan {% if block.settings.featured %}pf-ds-plan--featured{% endif %}" {{ block.shopify_attributes }}>
              <p class="pf-ds-plan__label">{{ block.settings.label }}</p>
              <h4 class="pf-ds-plan__name">{{ block.settings.name }}</h4>
              <p class="pf-ds-plan__price">{{ block.settings.price }}</p>
              <p class="pf-ds-plan__price-note">{{ block.settings.price_note }}</p>
              <div class="pf-ds-plan__rule"></div>
              <ul class="pf-ds-plan__list">
                {%- if block.settings.feat_1 != blank -%}<li>{{ block.settings.feat_1 }}</li>{%- endif -%}
                {%- if block.settings.feat_2 != blank -%}<li>{{ block.settings.feat_2 }}</li>{%- endif -%}
                {%- if block.settings.feat_3 != blank -%}<li>{{ block.settings.feat_3 }}</li>{%- endif -%}
                {%- if block.settings.feat_4 != blank -%}<li>{{ block.settings.feat_4 }}</li>{%- endif -%}
                {%- if block.settings.feat_off_1 != blank -%}<li class="disabled">{{ block.settings.feat_off_1 }}</li>{%- endif -%}
                {%- if block.settings.feat_off_2 != blank -%}<li class="disabled">{{ block.settings.feat_off_2 }}</li>{%- endif -%}
              </ul>
            </div>
          {%- endif -%}
        {%- endfor -%}
      </div>
    </div>
  </div>

  {%- comment -%} ===== DIVIDER ===== {%- endcomment -%}
  <div class="pf-ds__container">
    <div class="pf-ds-divider"><span class="pf-ds-divider__glyph">一 ☽ 一</span></div>
  </div>

  {%- comment -%} ===== CTA ===== {%- endcomment -%}
  <div class="pf-ds-cta">
    <div class="pf-ds-cta__inner">
      <span class="pf-ds-label" style="text-align:center;display:block">立即开始</span>
      <h3 class="pf-ds-cta__title">{{ section.settings.cta_title }}</h3>
      <p class="pf-ds-cta__sub">{{ section.settings.cta_sub }}</p>
      <div style="margin-bottom:32px">
        <span class="pf-ds-cta__coming">功能开发中 · Coming Soon</span>
      </div>
      <a href="{{ section.settings.cta_url }}" class="pf-ds-btn">
        {{ section.settings.cta_button }}
      </a>
    </div>
  </div>

</div>

{% schema %}
{
  "name": "电子祠堂",
  "tag": "section",
  "class": "pf-digital-shrine-section",
  "settings": [
    {
      "type": "header",
      "content": "Hero"
    },
    {
      "type": "text",
      "id": "overline",
      "label": "顶部标语",
      "default": "永恒的数字纪念空间"
    },
    {
      "type": "text",
      "id": "hero_title",
      "label": "主标题",
      "default": "电子祠堂"
    },
    {
      "type": "text",
      "id": "hero_title_accent",
      "label": "副标题（金色）",
      "default": "为挚爱建一座永不消逝的居所"
    },
    {
      "type": "textarea",
      "id": "hero_lead",
      "label": "引言",
      "default": "它离开了，但对它的思念从未消散。电子祠堂是一个永久在线的数字纪念空间，让您随时回到那些温柔的记忆里，也让更多爱它的人，找到一个共同缅怀的地方。"
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "主视觉图片"
    },
    {
      "type": "header",
